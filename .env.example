# ═══════════════════════════════════════════════════════════════
# EXPO CYPRUS — Environment Variables
# Bu dosyayı .env olarak kopyalayıp doldurun
# .env dosyası git'e GİRMEZ (.gitignore'da)
# ═══════════════════════════════════════════════════════════════

# ─── Uygulama ────────────────────────────────────────────────
APP_NAME="Expo Cyprus"
APP_ENV=production
APP_URL=https://expocyprus.com
APP_DEBUG=false
APP_TIMEZONE=Europe/Nicosia

# 32+ karakter random — production'da MUTLAKA değiştirin
# Üretmek için: php -r "echo bin2hex(random_bytes(32));"
APP_SECRET=__GENERATE_A_RANDOM_32CHAR_HEX_STRING__

# ─── Veritabanı (cPanel'de oluşturulan MySQL) ───────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cpaneluser_expocyprus
DB_USER=cpaneluser_dbuser
DB_PASS=__SET_DATABASE_PASSWORD__

# ─── Mail (cPanel SMTP) ──────────────────────────────────────
MAIL_DRIVER=smtp
MAIL_HOST=mail.expocyprus.com
MAIL_PORT=587
MAIL_USER=info@expocyprus.com
MAIL_PASS=__SET_MAIL_PASSWORD__
MAIL_FROM=info@expocyprus.com
MAIL_FROM_NAME="Expo Cyprus"
MAIL_ADMIN=info@expocyprus.com

# ─── reCAPTCHA (opsiyonel) ───────────────────────────────────
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ─── Analytics (artık CMS Settings'ten yönetilir) ──────────
GA_MEASUREMENT_ID=
FB_PIXEL_ID=

# ─── Session ─────────────────────────────────────────────────
SESSION_LIFETIME=120
SESSION_DRIVER=file

# ─── Deployment Webhook (GitHub auto-deploy) ────────────────
# /public/deploy-webhook.php endpoint'inde kullanılır
# GitHub webhook secret ile aynı olmalı
DEPLOY_WEBHOOK_SECRET=__GENERATE_A_RANDOM_SECRET__
DEPLOY_BRANCH=main
