# ─── Environment & secrets ───────────────
.env
.env.*.local
!.env.example

# ─── Composer ────────────────────────────
# vendor/ üretim ortamı için repo'da tutulur (cPanel'da composer çalıştıramıyoruz)
# /vendor/
composer.phar

# ─── Storage / cache / sessions ──────────
/storage/sessions/*
!/storage/sessions/.gitkeep
/storage/cache/*
!/storage/cache/.gitkeep
/storage/logs/*
!/storage/logs/.gitkeep

# ─── DEPLOY KEY — ASLA repo'ya girmemeli ────────────
/.deploy/
*.pem
id_rsa
id_ed25519
*_deploy_key
*_deploy_key.pub

# ─── User uploads — site içerikleri (CMS / blog / katalog) ───────
# Üretimde sunucuda saklanır, repo'ya GİRMEZ
/public/uploads/*
!/public/uploads/.gitkeep
!/public/uploads/.htaccess
!/public/uploads/*/.gitkeep

# ─── Asset görselleri ───────────────────────────────────────────
# WebP versiyonları repo'da (~7 MB toplam, 95% küçültme)
# Orijinal PNG/JPG'ler local'de var, repo'ya girmez
# Video'lar repo'da kalır (~4 MB hero-video.mp4)
/public/assets/images/*.png
/public/assets/images/hotels/*.png
/public/assets/images/hotels/*.jpg
/public/assets/images/stand-models/*.png
/public/assets/images/stand-models/*.jpg
/public/assets/images/furniture/*.png
/public/assets/images/furniture/*.jpg

# WebP'lere izin ver
!/public/assets/images/*.webp
!/public/assets/images/hotels/*.webp
!/public/assets/images/stand-models/*.webp
!/public/assets/images/furniture/*.webp

# küçük SVG ve ikonlar repo'da kalsın
!/public/assets/images/*.svg
!/public/assets/images/icons/
!/public/assets/img/
!/public/assets/images/.gitkeep

# ─── IDE / editor / AI tools ────────────
.vscode/
.idea/
.claude/
.cursor/
.aider*
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ─── OS ──────────────────────────────────
ehthumbs.db
$RECYCLE.BIN/

# ─── Node (frontend asset build, ileride lazım olursa) ───
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ─── Backup / temp ───────────────────────
*.bak
*.backup
*.tmp
*.log
*.sql.gz
*.tar.gz

# ─── PHPStan / Code quality ──────────────
.phpunit.result.cache
.phpunit.cache/
.php-cs-fixer.cache

# ─── Local DB dumps (sürüm kontrolü dışında) ──
/database/dumps/
/database/*.dump
